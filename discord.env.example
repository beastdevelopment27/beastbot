# Copy this file to `discord.env` and fill in real values.
# Do not commit `discord.env` if it contains secrets.

# Required — bot token from Developer Portal → Bot
TOKEN=YOUR_DISCORD_BOT_TOKEN

# Category where new ticket text channels are created
CATEGORY_ID=YOUR_OPEN_TICKET_CATEGORY_SNOWFLAKE

# Category where closed tickets are moved (archived; channel is not deleted)
CLOSED_CATEGORY_ID=YOUR_CLOSED_TICKET_CATEGORY_SNOWFLAKE

# Staff role — can see tickets and close them (role ID)
STAFF_ROLE_ID=YOUR_STAFF_ROLE_SNOWFLAKE

# Text channel — ticket opened/closed logs
LOG_CHANNEL_ID=YOUR_LOG_CHANNEL_SNOWFLAKE

# Optional — register /ticket to one guild immediately (recommended)
GUILD_ID=YOUR_GUILD_SNOWFLAKE

# Optional — application/client ID (slash registration); if omitted, fetched via API
CLIENT_ID=

# Text channel — ticket reviews (embed + stars from Leave Review modal)
REVIEW_CHANNEL_ID=YOUR_REVIEW_CHANNEL_SNOWFLAKE

# Role given automatically when someone joins (enable Server Members Intent on the bot)
JOIN_ROLE_ID=YOUR_AUTO_ROLE_SNOWFLAKE

# --- PostgreSQL (Neon) — transcript HTML on ticket close ---
# Example: postgresql://USER:PASSWORD@HOST/neondb?sslmode=require
DATABASE_URL=postgresql://USER:PASSWORD@YOUR_NEON_HOST/neondb?sslmode=require

# Optional: default table is ticket_transcripts (columns: channel_id, ticket_id UNIQUE, guild_id, channel_name, html, updated_at)
# POSTGRES_TRANSCRIPTS_TABLE=ticket_transcripts

# Transcript link button: site base only (trailing slash ok) → opens https://<host>/<channelId>
# Or full pattern: https://your-app.vercel.app/transcript/{channelId}
TRANSCRIPT_VIEW_URL=https://your-app.vercel.app

# Port for: npm run serve-transcripts
TRANSCRIPT_HTTP_PORT=3847

# Optional: disk fallback if Postgres has no row for that channel
# TRANSCRIPT_PUBLIC_DIR=data/transcripts

# "Ticket Closed" embed fields (optional overrides)
TICKET_CLOSE_REASON=Resolved
TICKET_CLAIMED_BY_DISPLAY=Not claimed

# Optional: role that may use /update (Administrators always can)
# UPDATE_ROLE_ID=
